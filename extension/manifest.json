{
  "manifest_version": 3,
  "name": "Bug Bridge",
  "version": "0.1.0",
  "description": "Capture full debugging context from any website and send it to Claude Code for automated fixing.",
  "permissions": [
    "activeTab",
    "cookies",
    "scripting",
    "nativeMessaging",
    "devtools",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "devtools_page": "devtools.html",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
